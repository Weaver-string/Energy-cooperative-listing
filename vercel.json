{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/verify\\.html",
      "dest": "/404.html",
      "status": 404
    },
    {
      "src": "/api/listing-requests/?",
      "dest": "/404.html",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
