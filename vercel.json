{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/verify\\.html",
      "dest": "/404.html",
      "status": 404
    },
    {
      "src": "/api/listing-requests/?",
      "dest": "/404.html",
      "status": 404
    },
    {
      "src": "/robots\\.txt",
      "dest": "/api/robots"
    },
    {
      "src": "/sitemap\\.xml",
      "dest": "/api/sitemap"
    },
    {
      "src": "/join",
      "dest": "/api/seo-join"
    },
    {
      "src": "/buy-electricity",
      "dest": "/api/seo-buy-electricity"
    },
    {
      "src": "/coops/([^/]+)",
      "dest": "/api/coops/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
